<style>
  .announcement-bar-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-weight: 400;
    font-size: 12px;
    line-height: 12px;
    text-align: center;
    padding: 12px 24px;
    position: sticky;
    top: 0;
    z-index: 1000;
    width: 100%;
    box-sizing: border-box;
    border-bottom: none;
    /* Smooth sticky transition */
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .announcement-bar-{{ section.id }} .announcement-bar__inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    flex-wrap: wrap;
    box-sizing: border-box;
  }

  .announcement-bar-{{ section.id }} .announcement-bar__text {
    display: inline;
    font-size: inherit;
    line-height: inherit;
    color: inherit;
  }

  .announcement-bar-{{ section.id }} .announcement-bar__highlighted {
    display: inline;
    font-size: inherit;
    line-height: inherit;
    color: inherit;
    border-bottom: {{ section.settings.border_width }}px solid {{ section.settings.text_color }};
    padding-bottom: 2px;
    /* ensure the underline sits close to the text */
    line-height: 1.2;
  }

  /* Mobile styles – font size reduced by ~20% */
  @media screen and (max-width: 749px) {
    .announcement-bar-{{ section.id }} {
      font-size: 10px; /* 12px * 0.833 ≈ 10px (~17% reduction, smooth) */
      line-height: 10px;
      padding: 10px 20px;
    }

    .announcement-bar-{{ section.id }} .announcement-bar__inner {
      padding: 0 20px;
      gap: 4px;
    }

    .announcement-bar-{{ section.id }} .announcement-bar__highlighted {
      padding-bottom: 1px;
      border-bottom-width: {{ section.settings.border_width | times: 0.8 | round: 1 }}px;
    }
  }

  /* Very small screens – keep text readable */
  @media screen and (max-width: 380px) {
    .announcement-bar-{{ section.id }} {
      font-size: 9px;
      line-height: 9px;
      padding: 8px 12px;
    }

    .announcement-bar-{{ section.id }} .announcement-bar__inner {
      padding: 0 12px;
      gap: 3px;
    }
  }
</style>

<div class="announcement-bar-{{ section.id }}" role="banner" aria-label="Announcement">
  <div class="announcement-bar__inner">
    <span class="announcement-bar__text">
      {{ section.settings.main_text }}
    </span>
    <span class="announcement-bar__highlighted">
      {{ section.settings.highlighted_text }}
    </span>
  </div>
</div>



{% schema %}
{
  "name": "KNR Announcement Bar",
    "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "text",
      "id": "main_text",
      "label": "Main text",
      "default": "Livraison estimée sous 48h",
      "info": "Text before the highlighted word"
    },
    {
      "type": "text",
      "id": "highlighted_text",
      "label": "Highlighted text (with underline)",
      "default": "consectetur.",
      "info": "This word will have a bottom border"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & border color",
      "default": "#FFFFFF"
    },
    {
      "type": "number",
      "id": "border_width",
      "label": "Border thickness (px)",
      "default": 1,
      "info": "Thickness of the underline below the highlighted word"
    }
  ],
  "presets": [
    {
      "name": "KNR Announcement Bar",
      "category": "Custom KNR"
    }
  ]
}
{% endschema %}
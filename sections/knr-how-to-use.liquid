{% assign section_heading = section.settings.heading %}
{% assign section_bg_color = section.settings.background_color %}
{% assign section_top_padding = section.settings.top_padding %}
{% assign section_bottom_padding = section.settings.bottom_padding %}

<style>
  .how-to-use-section-{{ section.id }} {
    --htu-bg-color: {{ section_bg_color }};
    --htu-desktop-padding-x: 40px;
    --htu-mobile-padding-x: 24px;
    --htu-desktop-top-padding: {{ section_top_padding }}px;
    --htu-desktop-bottom-padding: {{ section_bottom_padding }}px;
    --htu-mobile-top-padding: 48px;
    --htu-mobile-bottom-padding: 48px;
    --htu-heading-size: 32px;
    --htu-heading-line-height: 40px;
    --htu-title-size: 24px;
    --htu-title-line-height: 32px;
    --htu-step-size: 14px;
    --htu-step-line-height: 14px;
    --htu-body-size: 14px;
    --htu-body-line-height: 22px;
    --htu-gap-desktop: 16px;
    --htu-gap-mobile: 8px;
    --htu-card-width-mobile: min(84vw, 320px);
    background-color: var(--htu-bg-color);
    padding: var(--htu-desktop-top-padding) var(--htu-desktop-padding-x) var(--htu-desktop-bottom-padding);
    font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: #000000;
  }

  .how-to-use-section-{{ section.id }}__inner {
    max-width: 1600px;
    margin: 0 auto;
  }

  .how-to-use-section-{{ section.id }}__heading {
    margin: 0 0 40px;
    font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-weight: 400;
    font-size: var(--htu-heading-size);
    line-height: var(--htu-heading-line-height);
    letter-spacing: -0.04em;
    text-align: left;
    color: #000000;
  }

  .how-to-use-section-{{ section.id }}__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--htu-gap-desktop);
    align-items: start;
  }

  .how-to-use-section-{{ section.id }}__card {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .how-to-use-section-{{ section.id }}__media {
    width: 100%;
    margin-bottom: 20px;
  }

  .how-to-use-section-{{ section.id }}__image {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    height: auto;
    object-fit: cover;
    object-position: center;
  }

  .how-to-use-section-{{ section.id }}__placeholder {
    background: #f2eee8;
  }

  .how-to-use-section-{{ section.id }}__image--mobile {
    display: none;
  }

  .how-to-use-section-{{ section.id }}__content {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .how-to-use-section-{{ section.id }}__progress {
    display: none;
  }

  .how-to-use-section-{{ section.id }}__step {
    margin: 0;
    font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-weight: 400;
    font-size: var(--htu-step-size);
    line-height: var(--htu-step-line-height);
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: #000000;
  }

  .how-to-use-section-{{ section.id }}__title {
    margin: 0;
    font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-weight: 400;
    font-size: var(--htu-title-size);
    line-height: var(--htu-title-line-height);
    letter-spacing: -0.02em;
    color: #000000;
  }

  .how-to-use-section-{{ section.id }}__description {
    margin: 0;
    font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-weight: 400;
    font-size: var(--htu-body-size);
    line-height: var(--htu-body-line-height);
    letter-spacing: -0.02em;
    color: #000000;
    width: 100%;
    max-width: none;
  }

  @media screen and (max-width: 749px) {
    .how-to-use-section-{{ section.id }} {
      padding: var(--htu-mobile-top-padding) var(--htu-mobile-padding-x) var(--htu-mobile-bottom-padding);
    }

    .how-to-use-section-{{ section.id }}__heading {
      margin-bottom: 24px;
      font-size: 28px;
      line-height: 34px;
    }

    .how-to-use-section-{{ section.id }}__grid {
      display: flex;
      gap: var(--htu-gap-mobile);
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 4px;
      scrollbar-width: none;
    }

    .how-to-use-section-{{ section.id }}__grid::-webkit-scrollbar {
      display: none;
    }

    .how-to-use-section-{{ section.id }}__card {
      flex: 0 0 var(--htu-card-width-mobile);
      scroll-snap-align: start;
      min-width: 0;
    }

    .how-to-use-section-{{ section.id }}__image--desktop {
      display: none;
    }

    .how-to-use-section-{{ section.id }}__image--mobile {
      display: block;
    }

    .how-to-use-section-{{ section.id }}__progress {
      display: flex;
      justify-content: center;
      margin-top: 32px;
    }

    .how-to-use-section-{{ section.id }}__progress-track {
      position: relative;
      width: 140px;
      height: 2px;
      background-color: #D8D2C5;
      overflow: hidden;
      border-radius: 0;
    }

    .how-to-use-section-{{ section.id }}__progress-bar {
      position: absolute;
      top: 0;
      left: 0;
      width: 36px;
      height: 2px;
      background-color: #000000;
      border-radius: 0;
      transition: transform 0.08s linear;
      will-change: transform;
    }
  }
</style>

<section id="how-to-use-{{ section.id }}" class="how-to-use-section how-to-use-section-{{ section.id }}">
  <div class="how-to-use-section-{{ section.id }}__inner">
    {% if section_heading != blank %}
      <h2 class="how-to-use-section-{{ section.id }}__heading">{{ section_heading }}</h2>
    {% endif %}

    <div class="how-to-use-section-{{ section.id }}__grid">
      {% for block in section.blocks %}
        {% assign block_image = block.settings.image %}
        {% assign block_mobile_image = block.settings.mobile_image %}
        {% assign block_step_number = block.settings.step_number %}
        {% assign block_title = block.settings.title %}
        {% assign block_description = block.settings.description %}

        {% if block_mobile_image == blank %}
          {% assign block_mobile_image = block_image %}
        {% endif %}

        {% assign desktop_placeholder_classes = 'how-to-use-section-' | append: section.id | append: '__image how-to-use-section-' | append: section.id | append: '__placeholder how-to-use-section-' | append: section.id | append: '__image--desktop' %}
        {% assign mobile_placeholder_classes = 'how-to-use-section-' | append: section.id | append: '__image how-to-use-section-' | append: section.id | append: '__placeholder how-to-use-section-' | append: section.id | append: '__image--mobile' %}

        <article class="how-to-use-section-{{ section.id }}__card" {{ block.shopify_attributes }}>
          <div class="how-to-use-section-{{ section.id }}__media">
            {% if block_image != blank %}
              <img
                src="{{ block_image | image_url }}"
                alt=""
                loading="lazy"
                width="100%"
                height="auto"
                class="how-to-use-section-{{ section.id }}__image how-to-use-section-{{ section.id }}__image--desktop"
              />
            {% else %}
              {{ 'image' | placeholder_svg_tag: desktop_placeholder_classes }}
            {% endif %}

            {% if block_mobile_image != blank %}
              <img
                src="{{ block_mobile_image | image_url }}"
                alt=""
                loading="lazy"
                width="100%"
                height="auto"
                class="how-to-use-section-{{ section.id }}__image how-to-use-section-{{ section.id }}__image--mobile"
              />
            {% else %}
              {{ 'image' | placeholder_svg_tag: mobile_placeholder_classes }}
            {% endif %}
          </div>

          <div class="how-to-use-section-{{ section.id }}__content">
            {% if block_step_number != blank %}
              <p class="how-to-use-section-{{ section.id }}__step">{{ block_step_number }}</p>
            {% endif %}

            {% if block_title != blank %}
              <h3 class="how-to-use-section-{{ section.id }}__title">{{ block_title }}</h3>
            {% endif %}

            {% if block_description != blank %}
              <p class="how-to-use-section-{{ section.id }}__description">{{ block_description }}</p>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>

    <div class="how-to-use-section-{{ section.id }}__progress" aria-hidden="true">
      <div class="how-to-use-section-{{ section.id }}__progress-track">
        <span class="how-to-use-section-{{ section.id }}__progress-bar"></span>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var section = document.getElementById('how-to-use-{{ section.id }}');

    if (!section) {
      return;
    }

    var carousel = section.querySelector('.how-to-use-section-{{ section.id }}__grid');
    var progressBar = section.querySelector('.how-to-use-section-{{ section.id }}__progress-bar');
    var cards = section.querySelectorAll('.how-to-use-section-{{ section.id }}__card');

    if (!carousel || !progressBar || cards.length < 2) {
      return;
    }

    var track = section.querySelector('.how-to-use-section-{{ section.id }}__progress-track');
    var trackWidth = 140;
    var activeWidth = 36;
    var maxOffset = Math.max(trackWidth - activeWidth, 0);

    function updateProgress() {
      if (!carousel || !track || !progressBar) {
        return;
      }

      var containerWidth = carousel.clientWidth;
      var maxScroll = Math.max(carousel.scrollWidth - containerWidth, 0);
      var scrollLeft = carousel.scrollLeft;
      var ratio = maxScroll > 0 ? scrollLeft / maxScroll : 0;
      var offset = ratio * maxOffset;

      progressBar.style.transform = 'translateX(' + offset + 'px)';
    }

    function onResize() {
      trackWidth = track ? track.clientWidth : 140;
      maxOffset = Math.max(trackWidth - activeWidth, 0);
      updateProgress();
    }

    carousel.addEventListener('scroll', updateProgress, { passive: true });
    window.addEventListener('resize', onResize);
    window.addEventListener('orientationchange', onResize);

    updateProgress();
  })();
</script>

{% schema %}
{
  "name": "How To Use",
  "tag": "section",
  "class": "section-how-to-use",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How to use"
    },
    {
      "type": "color",

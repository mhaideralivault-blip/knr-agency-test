      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "number",
      "id": "top_padding",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "number",
      "id": "bottom_padding",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "card",
